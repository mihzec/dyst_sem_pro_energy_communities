<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<VBox prefHeight="102.0" prefWidth="199.0" spacing="4" xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="fh.technikum.energie.gui.controller.components.DateTimePickerController">

    <DatePicker fx:id="datePicker" prefHeight="26.0" prefWidth="184.0"/>

    <HBox alignment="CENTER" spacing="4">
        <TextField fx:id="inputHour" alignment="CENTER" prefWidth="40" promptText="HH"/>
        <Label text=":"/>
        <TextField fx:id="inputMinute" alignment="CENTER" prefWidth="40" promptText="mm"/>
    </HBox>
    <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0">
        <children>

            <Button contentDisplay="CENTER" onAction="#confirmBtnClicked" prefHeight="26.0" prefWidth="178.0"
                    text="OK"/>
        </children>
    </HBox>

    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
    </padding>

</VBox>
